{
    "version": 2,
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.html",
            "status": 200
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Permissions-Policy",
                    "value": "geolocation=(self), camera=(), microphone=(), payment=()"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                }
            ]
        }
    ],
    "regions": [
        "sin1"
    ]
}
