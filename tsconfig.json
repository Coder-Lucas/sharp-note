{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "include": [
        "./app/**/*.ts",
        "./app/**/*.tsx",
        "./app/**/*.d.ts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": [
        "./node_modules"
    ],
    "compilerOptions": {
        "baseUrl": "./",
        "rootDir": "./app",
        "outDir": "./dist",
        "declarationDir": "./types",
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false,
        "allowImportingTsExtensions": true,
        "target": "ES2015",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "strict": true,
        "lib": [
            "DOM",
            "ES2015"
        ],
        "plugins": [
            {
                "name": "next"
            }
        ],
        "types": [
            "next",
            "react",
            "node"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "paths": {
            "@/*": [
                "./app/*"
            ],
            "#/*": [
                "./components/*"
            ],
            "~/*": [
                "./*"
            ]
        },
        "incremental": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    }
}
