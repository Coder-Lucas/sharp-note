{
    "include": [
        "./src/**/*.ts",
        "./src/**/*.tsx",
        "./src/**/*.d.ts"
    ],
    "exclude": [
        "./node_modules",
        "./dist"
    ],
    "compilerOptions": {
        "baseUrl": "./",
        "rootDir": "./src",
        "outDir": "./dist",
        "declarationDir": "./types",
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false,
        "target": "ES2015",
        "module": "ESNext",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": true,
        "allowImportingTsExtensions": true,
        "strict": true,
        "typeRoots": [
            "./src/types",
            "./node_modules/@types"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@components/*": [
                "./components/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ],
            "@types/*": [
                "./src/types/*"
            ],
            "#/*": [
                "./src/components/app/*"
            ],
            "#header/*": [
                "./src/components/header/*"
            ],
            "#footer/*": [
                "./src/components/footer/*"
            ],
            "#home/*": [
                "./src/components/home/*"
            ],
            "#settings/*": [
                "./src/components/settings/*"
            ],
            "#about/*": [
                "./src/components/about/*"
            ],
            "#help/*": [
                "./src/components/help/*"
            ],
            "~/*": [
                "./*"
            ]
        }
    }
}
